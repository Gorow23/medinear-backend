# ================================================================
# .env — Environment Variables (SECRET — never share this file)
# ================================================================
# Copy this file, rename to .env, fill in your real values

# MongoDB Atlas connection string
# Get this from: mongodb.com/atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/medplus?retryWrites=true&w=majority

# JWT Secret — make this a long random string (keep it secret!)
# Example: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_to_random_string

# Port the server runs on
PORT=5000

# Frontend URL (your Netlify URL — for CORS)
FRONTEND_URL=https://medpluspharmacy.netlify.app
